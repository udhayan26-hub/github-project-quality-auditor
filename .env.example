# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scope: public_repo (read-only)
# Without a token: 60 requests/hour limit
# With a token: 5,000 requests/hour limit
GITHUB_TOKEN=your_github_personal_access_token_here

# Admin Dashboard Password (protects usage analytics page)
ADMIN_PASSWORD=your_secure_admin_password_here

# Database URL: sqlite:///analytics.db (local) or postgresql://user:pass@host:5432/db (production)
DATABASE_URL=sqlite:///analytics.db

# Salt for generating privacy-preserving visitor fingerprints
ANALYTICS_SALT=generate_a_random_hex_string_here

